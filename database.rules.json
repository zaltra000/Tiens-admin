{
    "rules": {
        "inventory": {
            ".read": true,
            ".write": "auth !== null && root.child('admins').child(auth.uid).val() === true",
            "$product": {
                ".validate": "newData.isBoolean()"
            }
        },
        "prices": {
            ".read": true,
            ".write": "auth !== null && root.child('admins').child(auth.uid).val() === true",
            "$product": {
                ".validate": "newData.isNumber() && newData.val() >= 0"
            }
        },
        "app_config": {
            ".read": true,
            ".write": "auth !== null && root.child('admins').child(auth.uid).val() === true",
            "latest_version": {
                ".validate": "newData.isString()"
            },
            "apk_url": {
                ".validate": "newData.isString()"
            },
            "apk_size_mb": {
                ".validate": "newData.isString()"
            },
            "force_update": {
                ".validate": "newData.isBoolean()"
            },
            "changelog_ar": {
                ".validate": "newData.isString()"
            },
            "changelog_en": {
                ".validate": "newData.isString()"
            }
        },
        "admins": {
            ".read": false,
            ".write": false
        },
        "$other": {
            ".read": false,
            ".write": false
        }
    }
}